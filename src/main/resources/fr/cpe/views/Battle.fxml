<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<AnchorPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fr.cpe.Controller.BattleController"
            prefHeight="917.0" prefWidth="1134.0">

    <BorderPane prefHeight="917.0" prefWidth="1134.0"
                style="-fx-background-color: linear-gradient(to bottom, #d8f0ff 0%, #e9f8ff 45%, #ffffff 100%);"
                AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <center>
            <VBox spacing="14.0">
                <padding>
                    <Insets top="18.0" right="20.0" bottom="16.0" left="20.0"/>
                </padding>

                <!-- Enemy -->
                <HBox spacing="20.0">
                    <VBox prefWidth="420.0" spacing="8.0"
                          style="-fx-background-color: rgba(255,255,255,0.92); -fx-background-radius: 16; -fx-border-color: #2a75bb; -fx-border-radius: 16; -fx-border-width: 3;">
                        <padding>
                            <Insets top="12.0" right="14.0" bottom="12.0" left="14.0"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="enemyNameLabel" text="RIVAL POKEMON"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f4e8c;"/>
                            <Label fx:id="enemyLevelLabel" text="  Lv.50"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1f4e8c;"/>
                        </HBox>

                        <VBox spacing="6.0">
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label text="PV"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <Label fx:id="enemyHpValueLabel" text="100 / 100"
                                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                            </HBox>
                            <ProgressBar fx:id="enemyHpBar" progress="1.0" prefWidth="380.0" prefHeight="28.0"
                                         style="-fx-accent: linear-gradient(to right, #16a34a 0%, #22c55e 50%, #16a34a 100%); -fx-control-inner-background: #e5e7eb; -fx-border-color: #1f4e8c; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0;"/>
                        </VBox>
                    </VBox>

                    <StackPane alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                        <Circle radius="95.0"
                                fill="rgba(255,255,255,0.55)"
                                stroke="#1f4e8c" strokeWidth="3.0"/>
                        <ImageView fx:id="enemySpriteView" fitWidth="220.0" fitHeight="220.0"
                                   preserveRatio="true"/>
                    </StackPane>
                </HBox>

                <StackPane prefHeight="220.0"
                           style="-fx-background-color: linear-gradient(to bottom, #a7f3d0 0%, #86efac 35%, #4ade80 100%); -fx-background-radius: 20; -fx-border-color: #2f855a; -fx-border-radius: 20; -fx-border-width: 3;">
                    <ImageView fx:id="battleBackgroundView" fitWidth="1020.0" fitHeight="220.0"
                               opacity="0.16"/>
                </StackPane>

                <!-- Player -->
                <HBox alignment="BOTTOM_LEFT" spacing="20.0">
                    <StackPane alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                        <Circle radius="115.0"
                                fill="rgba(255,255,255,0.55)"
                                stroke="#1f4e8c" strokeWidth="3.0"/>
                        <ImageView fx:id="playerSpriteView" fitWidth="300.0" fitHeight="300.0"
                                   preserveRatio="true"/>
                    </StackPane>

                    <VBox prefWidth="420.0" spacing="8.0"
                          style="-fx-background-color: rgba(255,255,255,0.94); -fx-background-radius: 16; -fx-border-color: #2a75bb; -fx-border-radius: 16; -fx-border-width: 3;">
                        <padding>
                            <Insets top="12.0" right="14.0" bottom="12.0" left="14.0"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="playerNameLabel" text="TON POKEMON"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f4e8c;"/>
                            <Label fx:id="playerLevelLabel" text="  Lv.50"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1f4e8c;"/>
                        </HBox>

                        <VBox spacing="6.0">
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label text="PV"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <Label fx:id="playerHpValueLabel" text=" "
                                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                            </HBox>
                            <ProgressBar fx:id="playerHpBar" progress="1.0" prefWidth="380.0" prefHeight="28.0"
                                         style="-fx-accent: linear-gradient(to right, #16a34a 0%, #22c55e 50%, #16a34a 100%); -fx-control-inner-background: #e5e7eb; -fx-border-color: #2a75bb; -fx-border-width: 2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0;"/>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </center>

        <bottom>
            <GridPane hgap="14.0" vgap="10.0" style="-fx-background-color: rgba(255,255,255,0.96); -fx-border-color: #1f4e8c; -fx-border-width: 3 0 0 0;">
                <padding>
                    <Insets top="14.0" right="20.0" bottom="18.0" left="20.0"/>
                </padding>

                <columnConstraints>
                    <ColumnConstraints percentWidth="62.0" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="38.0" hgrow="ALWAYS"/>
                </columnConstraints>

                <children>
                    <VBox fx:id="battleMessagePane" spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <children>
                            <Label text="Message de combat"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
                            <Label fx:id="battleMessageLabel" text="Un combat commence ! Que veux-tu faire ?"
                                   wrapText="true"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        </children>
                    </VBox>

                    <StackPane GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <children>
                            <GridPane fx:id="actionPane" hgap="10.0" vgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50.0" hgrow="ALWAYS"/>
                                    <ColumnConstraints percentWidth="50.0" hgrow="ALWAYS"/>
                                </columnConstraints>
                                <children>
                                    <Button fx:id="attackButton" text="ATTAQUE" onAction="#pressAttackButton" maxWidth="1.7976931348623157E308" prefHeight="54.0"
                                            style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: #ffcb05; -fx-text-fill: #1f4e8c; -fx-background-radius: 14; -fx-border-color: #2a75bb; -fx-border-radius: 14; -fx-border-width: 3;"
                                            GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <Button fx:id="bagButton" text="SAC" maxWidth="1.7976931348623157E308" prefHeight="54.0"
                                            style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: #e5e7eb; -fx-text-fill: #1f2937; -fx-background-radius: 14; -fx-border-color: #9ca3af; -fx-border-radius: 14; -fx-border-width: 2;"
                                            GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                    <Button fx:id="pokemonButton" text="POKEMON" maxWidth="1.7976931348623157E308" prefHeight="54.0"
                                            style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: #e5e7eb; -fx-text-fill: #1f2937; -fx-background-radius: 14; -fx-border-color: #9ca3af; -fx-border-radius: 14; -fx-border-width: 2;"
                                            GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                    <Button fx:id="runButton" text="FUITE" maxWidth="1.7976931348623157E308" prefHeight="54.0"
                                            style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: #fee2e2; -fx-text-fill: #991b1b; -fx-background-radius: 14; -fx-border-color: #fca5a5; -fx-border-radius: 14; -fx-border-width: 2;"
                                            GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                </children>
                            </GridPane>

                            <GridPane fx:id="movesPane" hgap="10.0" vgap="10.0" visible="false" managed="false">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50.0" hgrow="ALWAYS"/>
                                    <ColumnConstraints percentWidth="50.0" hgrow="ALWAYS"/>
                                </columnConstraints>
                                <children>
                                    <Button fx:id="moveButton1" text="CAPACITE 1" maxWidth="1.7976931348623157E308" prefHeight="54.0"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: #ffffff; -fx-text-fill: #0f172a; -fx-background-radius: 12; -fx-border-color: #94a3b8; -fx-border-radius: 12; -fx-border-width: 2;"
                                            GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <Button fx:id="moveButton2" text="CAPACITE 2" maxWidth="1.7976931348623157E308" prefHeight="54.0"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: #ffffff; -fx-text-fill: #0f172a; -fx-background-radius: 12; -fx-border-color: #94a3b8; -fx-border-radius: 12; -fx-border-width: 2;"
                                            GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                    <Button fx:id="moveButton3" text="CAPACITE 3" maxWidth="1.7976931348623157E308" prefHeight="54.0"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: #ffffff; -fx-text-fill: #0f172a; -fx-background-radius: 12; -fx-border-color: #94a3b8; -fx-border-radius: 12; -fx-border-width: 2;"
                                            GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                    <Button fx:id="moveButton4" text="CAPACITE 4" maxWidth="1.7976931348623157E308" prefHeight="54.0"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-background-color: #ffffff; -fx-text-fill: #0f172a; -fx-background-radius: 12; -fx-border-color: #94a3b8; -fx-border-radius: 12; -fx-border-width: 2;"
                                            GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                </children>
                            </GridPane>
                        </children>
                    </StackPane>
                </children>
            </GridPane>
        </bottom>
    </BorderPane>
</AnchorPane>
