<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/17.0.12"
           fx:controller="fr.cpe.Controller.IndexController"
           prefWidth="1134.0"
           prefHeight="917.0"
           stylesheets="@../css/index_style.css">

    <!-- === MAIN CONTAINER (toujours centré) === -->
    <VBox alignment="CENTER" spacing="40">

        <!-- LOGO -->
        <ImageView fitWidth="650" preserveRatio="true">
            <Image url="@../assets/logo.png"/>
        </ImageView>

        <!-- MENU BUTTONS -->
        <VBox alignment="CENTER" spacing="20">

            <Button text="START"
                    fx:id="startButton"
                    styleClass="menu-button,start-button"
                    prefWidth="250" prefHeight="50"
                    onAction="#pressStartButton"/>

            <Button text="QUITTER"
                    fx:id="quitButton"
                    styleClass="menu-button,quit-button"
                    prefWidth="250" prefHeight="50"
                    onAction="#pressLeftButton"/>
        </VBox>

        <!-- PRESS START TEXT -->
        <Label fx:id="pressStartLabel"
               text="PRESS START"
               styleClass="press-start-label"/>
    </VBox>

</StackPane>
