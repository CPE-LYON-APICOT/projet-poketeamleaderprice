<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/17.0.12"
           fx:controller="fr.cpe.Controller.IndexController">

    <!-- === MAIN CONTAINER (toujours centré) === -->
    <VBox alignment="CENTER" spacing="40">

        <!-- LOGO -->
        <ImageView fitWidth="650" preserveRatio="true">
            <Image url="@../assets/logo.png"/>
        </ImageView>

        <!-- MENU BUTTONS -->
        <VBox alignment="CENTER" spacing="20">

            <Button text="START"
                    fx:id="startButton"
                    prefWidth="250" prefHeight="50"
                    style="-fx-font-size: 24px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 20;
                           -fx-background-color: #ffcb05;
                           -fx-border-color: #2a75bb;
                           -fx-border-width: 4;
                           -fx-text-fill: #2a75bb;"
                    onAction="#pressStartButton"/>

            <Button text="QUITTER"
                    fx:id="quitButton"
                    prefWidth="250" prefHeight="50"
                    style="-fx-font-size: 22px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 20;
                           -fx-background-color: #d9534f;
                           -fx-border-color: #7a1f1c;
                           -fx-border-width: 4;
                           -fx-text-fill: white;"/>
        </VBox>

        <!-- PRESS START TEXT -->
        <Label fx:id="pressStartLabel" text="PRESS START"
               style="-fx-font-size: 26px;
                      -fx-font-weight: bold;
                      -fx-text-fill: white;
                      -fx-effect: dropshadow(gaussian, black, 8, 0.5, 0, 0);"/>
    </VBox>

</StackPane>
