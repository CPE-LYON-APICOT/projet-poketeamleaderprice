<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="917.0" prefWidth="1134.0" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.cpe.Controller.ChooseTeamController">
    <BorderPane prefHeight="917.0" prefWidth="1134.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <top>
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="pokemon-header">
                <padding>
                    <Insets bottom="16.0" left="20.0" right="20.0" top="20.0"/>
                </padding>
                <Label text="Votre nom :" styleClass="pokemon-label"/>
                <TextField fx:id="playerNameField" promptText="Entrez votre nom" prefWidth="260.0"/>
            </HBox>
        </top>

        <center>
            <HBox spacing="16.0">
                <padding>
                    <Insets left="20.0" right="20.0"/>
                </padding>
                <children>
                    <ListView fx:id="pokemonListView" HBox.hgrow="ALWAYS"/>
                    <TextArea fx:id="pokemonDescriptionArea" editable="false" wrapText="true"
                              promptText="Cliquez sur un pokémon pour afficher sa description." prefWidth="430.0"/>
                </children>
            </HBox>
        </center>

        <bottom>
            <VBox spacing="16.0">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="16.0"/>
                </padding>

                <children>
                    <GridPane hgap="10.0" vgap="10.0">
                        <children>
                            <Button fx:id="teamSlot1" text="Case 1" maxWidth="1.7976931348623157E308"
                                    GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <Button fx:id="teamSlot2" text="Case 2" maxWidth="1.7976931348623157E308"
                                    GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <Button fx:id="teamSlot3" text="Case 3" maxWidth="1.7976931348623157E308"
                                    GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                            <Button fx:id="teamSlot4" text="Case 4" maxWidth="1.7976931348623157E308"
                                    GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                            <Button fx:id="teamSlot5" text="Case 5" maxWidth="1.7976931348623157E308"
                                    GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                            <Button fx:id="teamSlot6" text="Case 6" maxWidth="1.7976931348623157E308"
                                    GridPane.columnIndex="5" GridPane.rowIndex="0"/>
                        </children>
                    </GridPane>

                    <HBox alignment="CENTER" spacing="20.0">
                        <children>
                            <Button fx:id="hostGameButton" text="Héberger une partie" styleClass="pokemon-main-button"/>
                            <Button fx:id="joinGameButton" text="Rejoindre une partie"
                                    styleClass="pokemon-main-button"/>
                        </children>
                    </HBox>
                </children>
            </VBox>
        </bottom>
    </BorderPane>
</AnchorPane>