<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="917.0" prefWidth="1134.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.cpe.Controller.ChooseTeamController" stylesheets="@../css/ChooseTeam_style.css">
    <BorderPane prefHeight="917.0" prefWidth="1134.0" styleClass="choose-team-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <top>
            <HBox alignment="CENTER" spacing="12.0" styleClass="pokemon-header">
                <padding>
                    <Insets bottom="16.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <Label styleClass="pokemon-label" text="Votre nom :" />
                <TextField fx:id="playerNameField" prefWidth="260.0" promptText="Entrez votre nom" />
            </HBox>
        </top>

        <center>
            <HBox spacing="16.0">
                <padding>
                    <Insets left="20.0" right="20.0" />
                </padding>
                <ListView fx:id="pokemonListView" HBox.hgrow="ALWAYS" />
                <TextArea fx:id="pokemonDescriptionArea" editable="false" prefWidth="430.0" promptText="Cliquez sur un pokémon pour afficher sa description." wrapText="true" />
            </HBox>
        </center>

        <bottom>
            <VBox spacing="16.0">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="16.0" />
                </padding>

                <!-- Les cases de l'équipe -->
                <GridPane hgap="10.0" vgap="10.0" maxWidth="1.7976931348623157E308">
                    <Button fx:id="teamSlot1" maxWidth="1.7976931348623157E308" minHeight="130.0" prefHeight="130.0" styleClass="team-slot" text="+" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <Button fx:id="teamSlot2" maxWidth="1.7976931348623157E308" minHeight="130.0" prefHeight="130.0" styleClass="team-slot" text="+" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Button fx:id="teamSlot3" maxWidth="1.7976931348623157E308" minHeight="130.0" prefHeight="130.0" styleClass="team-slot" text="+" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                    <Button fx:id="teamSlot4" maxWidth="1.7976931348623157E308" minHeight="130.0" prefHeight="130.0" styleClass="team-slot" text="+" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                    <Button fx:id="teamSlot5" maxWidth="1.7976931348623157E308" minHeight="130.0" prefHeight="130.0" styleClass="team-slot" text="+" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                    <Button fx:id="teamSlot6" maxWidth="1.7976931348623157E308" minHeight="130.0" prefHeight="130.0" styleClass="team-slot" text="+" GridPane.columnIndex="5" GridPane.rowIndex="0" />
               <columnConstraints>
                  <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                  <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                  <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                  <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                  <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                  <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints />
               </rowConstraints>
                </GridPane>

                <HBox alignment="CENTER" spacing="20.0">
                    <Button fx:id="hostGameButton" styleClass="pokemon-main-button" text="Héberger une partie" />
                    <Button fx:id="joinGameButton" styleClass="pokemon-main-button" text="Rejoindre une partie" />
                </HBox>
            </VBox>
        </bottom>
    </BorderPane>
</AnchorPane>
