<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane prefHeight="917.0" prefWidth="1134.0" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.cpe.Controller.ChooseTeamController">
    <BorderPane prefHeight="917.0" prefWidth="1134.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <top>
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="pokemon-header">
                <padding>
                    <Insets bottom="16.0" left="20.0" right="20.0" top="20.0"/>
                </padding>
                <Label text="Votre nom :" styleClass="pokemon-label"/>
                <TextField fx:id="playerNameField" promptText="Entrez votre nom" prefWidth="260.0"/>
            </HBox>
        </top>

        <center>
            <HBox spacing="16.0">
                <padding>
                    <Insets left="20.0" right="20.0"/>
                </padding>
                <ListView fx:id="pokemonListView" HBox.hgrow="ALWAYS"/>
                <TextArea fx:id="pokemonDescriptionArea" editable="false" wrapText="true"
                          promptText="Cliquez sur un pokémon pour afficher sa description." prefWidth="430.0"/>
            </HBox>
        </center>

        <bottom>
            <VBox spacing="16.0">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="16.0"/>
                </padding>

                <GridPane hgap="10.0" vgap="10.0">
                    <Button fx:id="teamSlot1" text="+" maxWidth="1.7976931348623157E308" minHeight="130.0"
                            prefHeight="130.0"
                            style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #2a75bb; -fx-background-color: linear-gradient(to bottom, #ffffff 0%, #d8ecff 100%); -fx-border-color: #2a75bb; -fx-border-width: 4; -fx-background-radius: 18; -fx-border-radius: 18;"
                            GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Button fx:id="teamSlot2" text="+" maxWidth="1.7976931348623157E308" minHeight="130.0"
                            prefHeight="130.0"
                            style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #2a75bb; -fx-background-color: linear-gradient(to bottom, #ffffff 0%, #d8ecff 100%); -fx-border-color: #2a75bb; -fx-border-width: 4; -fx-background-radius: 18; -fx-border-radius: 18;"
                            GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Button fx:id="teamSlot3" text="+" maxWidth="1.7976931348623157E308" minHeight="130.0"
                            prefHeight="130.0"
                            style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #2a75bb; -fx-background-color: linear-gradient(to bottom, #ffffff 0%, #d8ecff 100%); -fx-border-color: #2a75bb; -fx-border-width: 4; -fx-background-radius: 18; -fx-border-radius: 18;"
                            GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <Button fx:id="teamSlot4" text="+" maxWidth="1.7976931348623157E308" minHeight="130.0"
                            prefHeight="130.0"
                            style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #2a75bb; -fx-background-color: linear-gradient(to bottom, #ffffff 0%, #d8ecff 100%); -fx-border-color: #2a75bb; -fx-border-width: 4; -fx-background-radius: 18; -fx-border-radius: 18;"
                            GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                    <Button fx:id="teamSlot5" text="+" maxWidth="1.7976931348623157E308" minHeight="130.0"
                            prefHeight="130.0"
                            style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #2a75bb; -fx-background-color: linear-gradient(to bottom, #ffffff 0%, #d8ecff 100%); -fx-border-color: #2a75bb; -fx-border-width: 4; -fx-background-radius: 18; -fx-border-radius: 18;"
                            GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                    <Button fx:id="teamSlot6" text="+" maxWidth="1.7976931348623157E308" minHeight="130.0"
                            prefHeight="130.0"
                            style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #2a75bb; -fx-background-color: linear-gradient(to bottom, #ffffff 0%, #d8ecff 100%); -fx-border-color: #2a75bb; -fx-border-width: 4; -fx-background-radius: 18; -fx-border-radius: 18;"
                            GridPane.columnIndex="5" GridPane.rowIndex="0"/>
                </GridPane>

                <HBox alignment="CENTER" spacing="20.0">
                    <Button fx:id="hostGameButton" text="Héberger une partie" styleClass="pokemon-main-button"/>
                    <Button fx:id="joinGameButton" text="Rejoindre une partie"
                            styleClass="pokemon-main-button"/>
                </HBox>
            </VBox>
        </bottom>
    </BorderPane>
</AnchorPane>