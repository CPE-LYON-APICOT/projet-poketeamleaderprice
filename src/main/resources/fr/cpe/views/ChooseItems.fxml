<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<AnchorPane prefHeight="780.0" prefWidth="1024.0" styleClass="choose-items-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.cpe.Controller.ChooseItemsController">
    <stylesheets>
        <String fx:value="@../css/ChooseItems_style.css" />
    </stylesheets>
    <BorderPane prefHeight="780.0" prefWidth="1024.0" styleClass="choose-items-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <center>
            <HBox spacing="16.0" styleClass="choose-items-center">
                <padding>
                    <Insets left="24.0" right="24.0" />
                </padding>
                <ListView fx:id="itemListView" styleClass="items-list" HBox.hgrow="ALWAYS" />
                <TextArea fx:id="itemDescriptionArea" editable="false" prefWidth="420.0" promptText="Cliquez sur un item pour afficher sa description." styleClass="items-description" wrapText="true" />
            </HBox>
        </center>

        <bottom>
            <VBox spacing="14.0" styleClass="choose-items-bottom">
                <padding>
                    <Insets bottom="20.0" left="24.0" right="24.0" top="8.0" />
                </padding>

                <Label styleClass="choose-items-title" text="Choisis tes items" />
                <Label styleClass="choose-items-subtitle" text="Sélectionne les objets qui compléteront ta stratégie de combat." wrapText="true" />

                <GridPane hgap="12.0" styleClass="items-grid" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                    </columnConstraints>
                </GridPane>

                <HBox alignment="CENTER" spacing="20.0" styleClass="choose-items-actions">
                    <Button fx:id="backToTeamButton" styleClass="secondary-button" text="Retour equipe" />
                    <Button fx:id="hostGameButton" styleClass="pokemon-main-button" text="Héberger une partie" />
                    <Button fx:id="joinGameButton" styleClass="pokemon-main-button" text="Rejoindre une partie" />
                </HBox>
            </VBox>
        </bottom>
      <top>
         <Pane prefHeight="38.0" prefWidth="1024.0" styleClass="choose-items-top-spacer" BorderPane.alignment="CENTER" />
      </top>
    </BorderPane>
</AnchorPane>
