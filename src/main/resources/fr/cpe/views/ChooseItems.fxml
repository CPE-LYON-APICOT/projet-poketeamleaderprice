<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="917.0" prefWidth="1134.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.cpe.Controller.ChooseItemsController">

    <BorderPane prefHeight="917.0" prefWidth="1134.0" style="-fx-background-color: linear-gradient(to bottom, #fdfefe 0%, #edf6ff 45%, #dfeeff 100%);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <center>
            <HBox spacing="16.0">
                <padding>
                    <Insets left="20.0" right="20.0" />
                </padding>
                <ListView fx:id="itemListView" HBox.hgrow="ALWAYS" />
                <TextArea fx:id="itemDescriptionArea" editable="false" prefWidth="430.0" promptText="Cliquez sur un item pour afficher sa description." wrapText="true" />
            </HBox>
        </center>

        <bottom>
            <VBox spacing="16.0">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="16.0" />
                </padding>

                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2a75bb;" text="Choisis tes items" />

                <GridPane hgap="12.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="16.6666666667" />
                    </columnConstraints>
                </GridPane>

                <HBox alignment="CENTER" spacing="20.0">
                    <Button fx:id="backToTeamButton" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 16; -fx-background-color: #f2f2f2; -fx-border-color: #bdbdbd; -fx-border-width: 2;" text="Retour equipe" />
                    <Button fx:id="hostGameButton" styleClass="pokemon-main-button" text="Héberger une PartieService" />
                    <Button fx:id="joinGameButton" styleClass="pokemon-main-button" text="Rejoindre une PartieService" />
                </HBox>
            </VBox>
        </bottom>
      <top>
         <Pane prefHeight="64.0" prefWidth="1134.0" BorderPane.alignment="CENTER" />
      </top>
    </BorderPane>
</AnchorPane>
